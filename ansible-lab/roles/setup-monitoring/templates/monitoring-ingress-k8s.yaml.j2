apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: prometheus-ingress

spec:
  ingressClassName: nginx
  rules:
    - host: prometheus.{{ hostvars['worker1']['ansible_host'] }}.nip.io
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: monitoring-kube-prometheus-prometheus
                port:
                  number: 9090
    - host: prometheus.{{ hostvars['worker1']['private_ip'] }}.nip.io
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: monitoring-kube-prometheus-prometheus
                port:
                  number: 9090
---
